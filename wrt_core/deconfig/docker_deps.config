# Docker Stack Dependencies for nftables Backend
# This file contains dependencies required for Docker v29.3.x with nftables default

# Core docker dependencies
# CONFIG_PACKAGE_fuse-overlayfs is not set
# CONFIG_PACKAGE_kmod-crypto-acompress is not set
# CONFIG_PACKAGE_kmod-crypto-blake2b is not set
# CONFIG_PACKAGE_kmod-crypto-xxhash is not set
# CONFIG_PACKAGE_kmod-fs-btrfs is not set
# CONFIG_PACKAGE_kmod-lib-lzo is not set
# CONFIG_PACKAGE_kmod-lib-raid6 is not set
# CONFIG_PACKAGE_kmod-lib-xor is not set
# CONFIG_PACKAGE_kmod-lib-xxhash is not set
# CONFIG_PACKAGE_kmod-lib-zlib-deflate is not set
# CONFIG_PACKAGE_kmod-lib-zlib-inflate is not set
# CONFIG_PACKAGE_kmod-lib-zstd is not set
# CONFIG_PACKAGE_kmod-br-netfilter is not set

# Keep these iptables-related modules for current dockerd package DEPENDS.
# They are compatibility/runtime requirements in upstream OpenWrt dockerd Makefile.
# CONFIG_PACKAGE_kmod-ipt-nat is not set
# CONFIG_PACKAGE_kmod-ipt-nat6 is not set
# CONFIG_PACKAGE_kmod-ipt-physdev is not set
# CONFIG_PACKAGE_kmod-nf-ipvs is not set
# CONFIG_PACKAGE_kmod-nf-nat6 is not set
# CONFIG_PACKAGE_kmod-nft-queue is not set
# CONFIG_PACKAGE_kmod-dummy is not set
# CONFIG_PACKAGE_kmod-veth is not set
# CONFIG_PACKAGE_iptables-mod-extra is not set

# nftables backend support
# CONFIG_PACKAGE_nftables is not set
# CONFIG_PACKAGE_kmod-nft-nat is not set
# CONFIG_PACKAGE_kmod-nft-netdev is not set

# iptables-nft compatibility layer (for coexistence)
# CONFIG_PACKAGE_iptables-nft is not set
# CONFIG_PACKAGE_ip6tables-nft is not set
